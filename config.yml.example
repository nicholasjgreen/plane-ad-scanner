# plane-ad-scanner configuration
# Copy to config.yml and edit to suit your search criteria.

# Cron expression for automatic scanning (node-cron format).
# Default: every 6 hours. Set to null to disable automatic scheduling.
schedule: "0 */6 * * *"

web:
  port: 3000

# Optional: use a local Ollama model for site verification instead of Anthropic.
# Eliminates rate limits and API costs for verification. Requires Ollama running locally
# with a tool-calling model pulled (e.g. ollama pull qwen2.5:7b).
# On Linux with Docker: use the host IP instead of localhost (e.g. http://172.17.0.1:11434).
# Comment out or set to null to use Anthropic (claude-haiku) for verification.
#
# ollama:
#   url: "http://host.docker.internal:11434"   # Mac/Windows
#   url: "http://localhost:11434"               # running outside Docker
#   verification_model: "qwen2.5:7b"

agent:
  token_budget_per_run: 50000   # Max tokens across all agents in one scan run
  max_turns_per_agent: 10       # Max tool-call turns per agent invocation
  scraper_model: "claude-haiku-4-5-20251001"   # Model for Scraper agents (fast, low cost)
  matcher_model: "claude-sonnet-4-6"           # Model for Matcher agent (better reasoning)
  require_approval: false       # When true, pauses after scoring for user confirmation

# Interest criteria for the built-in scoring engine.
# Each listing is scored 0–100 based on how many criteria it satisfies (weighted).
# Superseded by feature 002's InterestProfile system when integrated.
criteria:
  - type: type_match
    pattern: "cessna 172"   # Case-insensitive match against aircraft type, make, or model
    weight: 3

  - type: price_range
    min: 20000
    max: 80000              # GBP
    weight: 2

  - type: year_min
    yearMin: 1990
    weight: 1

  - type: location_contains
    locationPattern: "yorkshire"
    weight: 1

# Sites to scan.
# NOTE (feature 003): Sites are now managed via the admin UI at /admin.
# Add sites through the browser — the scanner will verify each site before enabling it.
# The 'sites:' array below is no longer used; it is kept here as documentation only.
#
# sites:
#   - name: "Trade-A-Plane"
#     url: "https://www.trade-a-plane.com/search?category=Single+Engine+Piston"
#   - name: "Controller"
#     url: "https://www.controller.com/listings/aircraft/for-sale/list/category/single-engine-piston-aircraft"
sites: []
